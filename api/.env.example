# Turso database
# Get these from: turso db show chorify-theronv --url && turso db tokens create chorify-theronv
TURSO_URL=libsql://chorify-theronv-theronv.aws-us-west-2.turso.io
TURSO_AUTH_TOKEN=

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=

# Cron job protection secret — generate with: openssl rand -hex 16
# Set this same value in vercel.json or cron-job.org's Authorization header
CRON_SECRET=
