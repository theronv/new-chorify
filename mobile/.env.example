# Copy this file to .env.local (gitignored) and fill in your values.
#
# EXPO_PUBLIC_API_URL
#   Development : your machine's LAN IP so the iOS Simulator / Android Emulator
#                 can reach the local API server.
#                 iOS Simulator  → http://<LAN-IP>:3000
#                 Android Emulator → http://10.0.2.2:3000
#   Production  : your deployed API URL (set in EAS project env vars,
#                 not in a committed file).
#
# Find your LAN IP:
#   macOS  → ipconfig getifaddr en0
#   Linux  → hostname -I | awk '{print $1}'
EXPO_PUBLIC_API_URL=http://192.168.1.X:3000
