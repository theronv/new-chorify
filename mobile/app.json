{
  "expo": {
    "name": "Chorify",
    "slug": "chorify",
    "scheme": "chorify",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/AppIcon~ios-marketing.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/AppIcon~ios-marketing.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4F2F0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chorify.app",
      "buildNumber": "6",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Chorify needs access to your photos to set profile avatars.",
        "NSCameraUsageDescription": "Chorify needs access to your camera to take profile photos.",
        "NSUserNotificationsUsageDescription": "Chorify sends reminders when household tasks are due."
      }
    },
    "web": {
      "favicon": "./assets/AppIcon~ios-marketing.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/AppIcon~ios-marketing.png",
          "color": "#486966",
          "defaultChannel": "default"
        }
      ],
      "expo-background-fetch",
      [
        "expo-image-picker",
        {
          "photosPermission": "Chorify needs access to your photos to set profile avatars.",
          "cameraPermission": "Chorify needs access to your camera to take profile photos."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "5057828e-6aa6-4e50-91ed-7d5d585bb080"
      }
    },
    "owner": "theronv"
  }
}
